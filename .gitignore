# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Environment variables — NEVER commit files with real secrets ──────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow example/template files (no real values)
!.env.example
!.env.production.example

# ── ECC / Claude Code dev tooling (local only) ────────────────────────────────
.ecc/

# ── Test coverage ─────────────────────────────────────────────────────────────
/coverage

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
